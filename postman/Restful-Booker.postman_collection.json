    {
      "name": "Security",
      "item": [
        {
          "name": "SQL Injection in Auth",
          "event": [
            {
              "listen": "test",
              "script": {
                "exec": [
                  "pm.test('SQL injection does not return token', function () {",
                  "    var jsonData = pm.response.json();",
                  "    pm.expect(jsonData).to.not.have.property('token');",
                  "});"
                ],
                "type": "text/javascript"
              }
            }
          ],
          "request": {
            "method": "POST",
            "header": [
              { "key": "Content-Type", "value": "application/json" }
            ],
            "body": {
              "mode": "raw",
              "raw": "{\n    \"username\": \"' OR '1'='1\",\n    \"password\": \"' OR '1'='1\"\n}"
            },
            "url": {
              "raw": "{{baseUrl}}/auth",
              "host": ["{{baseUrl}}"],
              "path": ["auth"]
            }
          }
        },
        {
          "name": "Access Without Token (PUT)",
          "event": [
